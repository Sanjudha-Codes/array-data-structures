""Dutch national flag algorithm""

class Solution:
    def sort012(self, arr):
        # code here
        i,j,k=0,0,len(arr)-1
        
        while j<=k:
            if arr[j]==0:
                arr[i],arr[j]=arr[j],arr[i]
                j+=1
                i+=1
            elif arr[j]==2: 
                arr[k],arr[j]=arr[j],arr[k]
                k-=1
            else:
                j+=1
